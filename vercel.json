{
  "buildCommand": "npm run build",
  "framework": "nextjs",
  "env": {
    "WEBHOOK_API_KEY": "@webhook_api_key",
    "DATABASE_URL": "@database_url"
  },
  "headers": [
    {
      "source": "/api/:path*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    }
  ]
}
